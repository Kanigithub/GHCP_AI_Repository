{
  "environment": "stage",
  "orchestrator": "kubernetes",
  "kubernetes": {
    "namespace": "staging",
    "deployment_name": "app-deployment",
    "container_name": "app-container",
    "replicas": 2
  },
  "health_check_url": "https://staging-api.example.com/health",
  "health_check_interval": 15,
  "health_check_timeout": 90,
  "services": [
    "api",
    "database",
    "cache",
    "monitoring"
  ],
  "deployment_timeout": 480,
  "auto_rollback_on_failure": true,
  "resources": {
    "memory_limit": "2GB",
    "cpu_limit": "1"
  },
  "approval": {
    "required": false
  }
}
